#set page(paper: "a4", margin: (left: 2.5cm, right: 2.5cm, top: 2cm, bottom: 2cm))
#set text(font: "New Computer Modern", size: 12pt)
#set par(justify: true, leading: 0.65em, first-line-indent: 2em)
#set heading(numbering: "1.")

#align(center)[
  #text(size: 18pt, weight: "bold")[报告标题]
  #v(0.5em)
  #text(size: 11pt)[作者、单位、日期]
]

#v(1.5em)
